   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"c9befaf3\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Run Forge training on Modal\\n\",\n",
    "    \"This notebook defines a Modal app and function that run the Forge pretraining and fine-tuning pipeline remotely.\\n\",\n",
    "    \"\\n\",\n",
    "    \"To run on Modal, export this notebook as a Python script (e.g. `forge_modal.py`) and then run:\\n\",\n",
    "    \"- `modal run forge_modal.py::main`\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"5fdc5020\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Imports\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"363a1e65\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import modal\\n\",\n",
    "    \"from modal import App, Image, Secret\\n\",\n",
    "    \"\\n\",\n",
    "    \"from forge.embeddings import Forge\\n\",\n",
    "    \"from forge.pipeline import pretrain, finetune_integral_gap\\n\",\n",
    "    \"from forge.utils import Constants\\n\",\n",
    "    \"\\n\",\n",
    "    \"import os\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"e5652158\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Data\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"debfeea7\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Name of the Modal Secret that holds your HF token\\n\",\n",
    "    \"HF_SECRET = \\\"hf-token\\\"  # TODO: create this secret in Modal and store HF_TOKEN in it\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Modal app and base image definition\\n\",\n",
    "    \"app = App(\\\"forge-modal-training\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"image = (\\n\",\n",
    "    \"    Image.debian_slim(python_version=\\\"3.12\\\")\\n\",\n",
    "    \"    .pip_install(\\\"torch\\\", \\\"pyyaml\\\", \\\"tqdm\\\", \\\"numpy\\\", \\\"pandas\\\", \\\"scikit-learn\\\", \\\"scipy\\\", \\\"huggingface-hub\\\", \\\"gurobi\\\", \\\"torch-geometric\\\", \\\"vector-quantize-pytorch\\\")\\n\",\n",
    "    \")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"251c87a4\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Pre-Train\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"0b2fd9e1\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"@app.function(image=image, secrets=[Secret.from_name(HF_SECRET_NAME)], timeout=60 * 60 * 10)\\n\",\n",
    "    \"def run_pretrain_and_finetune():\\n\",\n",
    "    \"    \\\"\\\"\\\"Download data, pretrain Forge, then fine-tune on integral gap using Modal.\\\"\\\"\\\"\\n\",\n",
    "    \"    # Get token from environment (provided via Modal Secret)\\n\",\n",
    "    \"    token = os.environ.get(\\\"HF_TOKEN\\\", HF_SECRET)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Clone the Forge GitHub repository when running in a fresh environment\\n\",\n",
    "    \"    # If the directory already exists, this is a no-op.\\n\",\n",
    "    \"    import os, subprocess\\n\",\n",
    "    \"\\n\",\n",
    "    \"    REPO_URL = \\\"https://github.com/skadio/forge.git\\\"\\n\",\n",
    "    \"    REPO_DIR = \\\"forge\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if not os.path.exists(REPO_DIR):\\n\",\n",
    "    \"        subprocess.check_call([\\\"git\\\", \\\"clone\\\", REPO_URL])\\n\",\n",
    "    \"        os.chdir(REPO_DIR)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        os.chdir(REPO_DIR)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Download MIP instances\\n\",\n",
    "    \"    # NOTE: path is relative to the project root when running on Modal\\n\",\n",
    "    \"    subprocess.call(f\\\"python data/download.py --token {token}\\\", shell=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Forge model with its pre-training configuration\\n\",\n",
    "    \"    forge = Forge(train_config_yaml=\\\"./forge/configs/train_config.yaml\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Pretrain Forge on a set of MIP instances in the given input folder\\n\",\n",
    "    \"    # The pretrained model pickle is stored as output_forge_pretrained_pkl\\n\",\n",
    "    \"    # The intermediate mip_to_mipinfo pickle is stored as output_mip_to_mipinfo_pkl\\n\",\n",
    "    \"    pretrain(\\n\",\n",
    "    \"        forge=forge,\\n\",\n",
    "    \"        input_mip_folder=\\\"./data/instances/\\\",\\n\",\n",
    "    \"        input_mip_instances_file=\\\"./data/configs/all.txt\\\",\\n\",\n",
    "    \"        output_mip_to_mipinfo_pkl=\\\"./models/pretrain_clusters_mip_to_mipinfo.pkl\\\",\\n\",\n",
    "    \"        output_forge_pretrained_pkl=\\\"./models/forge_pretrained.pkl\\\",\\n\",\n",
    "    \"        output_log_file=\\\"./models/forge_pretrained.log\\\",\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Reload Forge with the same training config for fine-tuning\\n\",\n",
    "    \"    forge = Forge(train_config_yaml=\\\"./forge/configs/train_config.yaml\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Fine-tune Forge to predict integral gaps\\n\",\n",
    "    \"    finetune_integral_gap(\\n\",\n",
    "    \"        forge=forge,\\n\",\n",
    "    \"        input_forge_pkl=\\\"./models/forge_pretrained.pkl\\\",\\n\",\n",
    "    \"        model_type=Constants.FORGE_FINE_TUNE_INTEGRAL_GAP,\\n\",\n",
    "    \"        input_mip_folder=\\\"./data/instances/\\\",\\n\",\n",
    "    \"        input_mip_instances_file=\\\"./data/configs/tune_integral_gap.txt\\\",\\n\",\n",
    "    \"        output_forge_finetuned_pkl=\\\"./models/forge_integral_gap.pkl\\\",\\n\",\n",
    "    \"        output_mip_to_gapinfo_pkl=\\\"./models/mip_to_gapinfo.pkl\\\",\\n\",\n",
    "    \"        num_parallel_workers=10\\n\",\n",
    "    \"    )\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"2fbacc10\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Fine Tune\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"5d08fac2\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"@app.local_entrypoint()\\n\",\n",
    "    \"def main():\\n\",\n",
    "    \"    \\\"\\\"\\\"Entry point used when running via `modal run`.\\\",\\\"\\\"\\\"\\n\",\n",
    "    \"    run_pretrain_and_finetune.remote()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"c09d7f2a\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Notebook Run \"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"1eda20e6\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"with modal.enable_output():\\n\",\n",
    "    \"    with app.run():\\n\",\n",
    "    \"        run_pretrain_and_finetune.remote()\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
